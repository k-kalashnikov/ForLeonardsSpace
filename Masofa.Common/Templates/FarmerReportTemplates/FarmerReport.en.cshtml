@using System
@using Masofa.Common.Models.MasofaAnaliticReport
@model FarmerRecomendationReport
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Recommendations for farmers</title>
    <style>
        :root {
            --green: #396d55;
            --ink: #202428;
            --muted: #7d8a85;
            --border: #DFE7E3;
            --page-bg: #fff;
        }

        html, body {
            margin: 0;
            padding: 0;
            background: #e0ebe4;
            font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
            color: var(--ink);
            line-height: 1.4;
        }

        @@page {
            size: A4;
            margin: 12mm;
        }

        .page {
            width: 210mm;
            min-height: 297mm;
            box-sizing: border-box;
            background: var(--page-bg);
            margin: 12px auto;
            padding: 14mm;
            page-break-after: always;
            position: relative;
        }

        /* Обложка */
        .cover {
            background: linear-gradient(135deg, #396d55 0%, #2d5a47 100%);
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 30mm 20mm;
        }

        .cover-title {
            font-size: 24px;
            font-weight: 700;
            margin: 20px 0 10px;
        }

        .cover-subtitle {
            font-size: 16px;
            margin: 0;
        }

        .cover-footer {
            position: absolute;
            bottom: 14mm;
            left: 14mm;
            right: 14mm;
            display: flex;
            justify-content: space-between;
            font-size: 10px;
            color: rgba(255,255,255,0.8);
        }

        /* Основная страница */
        .header-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border);
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo-masofa {
            width: 160px;
            height: 36px;
        }

        .qr-code {
            width: 80px;
            height: 80px;
            border: 1px solid var(--border);
        }

        .header-right {
            text-align: right;
            font-size: 12px;
            color: var(--muted);
        }

        h1 {
            font-size: 24px;
            font-weight: 700;
            margin: 0 0 10px;
        }

        h2 {
            font-size: 18px;
            font-weight: 700;
            color: var(--green);
            margin: 20px 0 10px;
        }

        h3 {
            font-size: 14px;
            font-weight: 600;
            margin: 15px 0 8px;
        }

        .muted {
            color: var(--muted);
            font-size: 12px;
            margin: 0 0 15px;
        }

        .table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
            margin: 10px 0;
        }

            .table th,
            .table td {
                border: 1px solid var(--border);
                padding: 6px 8px;
                vertical-align: middle;
                text-align: center;
            }

            .table th {
                background-color: #f8faf8;
                font-weight: 600;
            }

        .chart img {
            width: 100%;
            height: auto;
            display: block;
        }

        .avoid {
            break-inside: avoid;
            page-break-inside: avoid;
        }

        .print-footer {
            position: absolute;
            bottom: 14mm;
            left: 14mm;
            right: 14mm;
            display: flex;
            justify-content: space-between;
            font-size: 10px;
            color: #667;
        }
    </style>
</head>
<body>

    <!-- Page 1: Обложка -->
    <section class="page cover">
        @if (!string.IsNullOrEmpty(Model.MinistrySvg))
        {
            <div style="text-align: center; margin: 40px 0;">
                <img src="data:image/svg+xml;base64,@Model.MinistrySvg" style="width: 250px; height: auto;" />
            </div>
        }
        <h1 class="cover-title">Ministry of Agriculture<br>Republic of Uzbekistan</h1>
        <h3 class="cover-subtitle">Crop analysis and recommendations</h3>
        <div class="cover-footer">
            <span>@Model.Header.ReportNumber • @Model.Header.ReportDate.ToString("dd.MM.yyyy")</span>
            <span>Page 1 of 6</span>
        </div>
    </section>


    <!-- Page 2: Основная информация -->
    <section class="page">
        <div class="header-row">
            <div class="header-left">
                <img class="logo-masofa" src="data:image/svg+xml;base64,@Model.LogoSvgBase64" alt="MASOFA YER" />
            </div>
            <div class="header-right">
                @Model.Header.ReportDate.ToString("dd.MM.yyyy")<br />
                @Model.Header.ReportNumber
            </div>
        </div>

        <p class="muted">
            These recommendations are based on information from the system, satellite monitoring of crops and standard agricultural recommendations.
        </p>

        <!-- === Блок общей информации в сетке === -->
        <h2>General information</h2>

        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 15px; font-size: 12px; position: relative;">
            <div>
                <strong>Region Name</strong><br />
                @Model.Header.Region
            </div>
            <div>
                <strong>Crop Name</strong><br />
                @Model.Header.CropName
            </div>
            <div>
                <strong>Cadastral Number</strong><br />
                @Model.Header.CadastralNumber
            </div>
            <div>
                <strong>Field ID</strong><br />
                @Model.Header.FieldIdText
            </div>
            <div>
                <strong>District Name</strong><br />
                @Model.Header.District
            </div>
            <div>
                <strong>Area</strong><br />
                @Model.Header.AreaHa ha
            </div>
            <div>
                <strong>Coordinates (WGS 84)</strong><br />
                @Model.Header.Wgs84
            </div>
            <!-- Пустой блок для выравнивания -->
            <div></div>

            <!-- QR-код — абсолютное позиционирование -->
            @if (!string.IsNullOrEmpty(Model.QrSvgBase64))
            {
                <div style="position: absolute; top: 30px; right: 90px; transform: translateX(10px); display: flex; align-items: center; justify-content: center; padding: 10px;">
                    <img src="data:image/svg+xml;base64,@Model.QrSvgBase64" alt="QR Code" style="width: 80px; height: 80px;" />
                </div>
            }
        </div>

        <!-- Soil data -->
        <h3>Soil data</h3>
        <div class="muted">Soil type — <b>@Model.Soil.SoilType</b></div>
        <table class="table avoid">
            <thead>
                <tr>
                    <th>Analysis date</th>
                    <th>pH</th>
                    <th>Humus, %</th>
                    <th>N (mg/kg)</th>
                    <th>P (mg/kg)</th>
                    <th>Sand, %</th>
                    <th>Clay, %</th>
                    <th>Density (g/cm³)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Soil.Rows)
                {
                    <tr>
                        <td>@r.AnalysisDate.ToString("dd.MM.yyyy")</td>
                        <td>@(r.Ph?.ToString("F1") ?? "—")</td>
                        <td>@(r.HumusPercent?.ToString("F1") ?? "—")</td>
                        <td>@(r.N?.ToString("F1") ?? "—")</td>
                        <td>@(r.P?.ToString("F1") ?? "—")</td>
                        <td>@(r.SandPercent?.ToString("F1") ?? "—")</td>
                        <td>@(r.ClayPercent?.ToString("F1") ?? "—")</td>
                        <td>@(r.Density?.ToString("F1") ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>

        <h3>@Model.Fertilization.Title</h3>
        <table class="table avoid">
            <thead>
                <tr>
                    <th>Crop</th>
                    <th>Fertilizer type</th>
                    <th>Manure, кг/ha</th>
                    <th>N</th>
                    <th>P</th>
                    <th>K</th>
                    <th>Spring</th>
                    <th>Before sowing</th>
                    <th>With sowing</th>
                    <th>application 1</th>
                    <th>application 2</th>
                    <th>application 3</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@Model.Fertilization.Table.Crop</td>
                    <td>@Model.Fertilization.Table.Manure</td>
                    <td>@Model.Fertilization.Table.ManureKgHa</td>
                    <td>@Model.Fertilization.Table.NKgHa</td>
                    <td>@Model.Fertilization.Table.PKgHa</td>
                    <td>@Model.Fertilization.Table.KKgHa</td>
                    <td>@Model.Fertilization.Table.Spring</td>
                    <td>@Model.Fertilization.Table.Spring</td>
                    <td>@Model.Fertilization.Table.BeforeSowing</td>
                    <td>@Model.Fertilization.Table.WithSowing</td>
                    <td>@Model.Fertilization.Table.Topdress1</td>
                    <td>@Model.Fertilization.Table.Topdress2</td>
                </tr>
            </tbody>
        </table>

        <div style="text-align: center; margin: 20px 0;">
            <img src="data:image/svg+xml;base64,@Model.GrowthStageSvg" alt="Этапы развития" style="width: 100%; height: auto; max-width: 800px;" />
        </div>

        <h3 style="margin-top:18px">Stages of vegetative development</h3>
        <table class="table avoid">
            <thead>
                <tr>
                    <th>Stages</th>
                    <th>Days</th>
                    <th>Sum of Active Temperatures</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.GrowthStages.Rows)
                {
                    <tr>
                        <td>@r.Stage</td>
                        <td>@r.Days</td>
                        <td>@r.ActiveTempSum</td>
                    </tr>
                }
            </tbody>
        </table>
        <p class="muted">Current phase: <b>@Model.GrowthStages.CurrentPhase</b></p>

        <!-- Нормы полива -->
        <h3>Irrigation standards</h3>
        <table class="table avoid">
            <thead>
                <tr>
                    <th>Crop</th>
                    <th>Sprinkler irrigation, m³/ha</th>
                    <th>Drip irrigation, m³/ha</th>
                    <th>Ditch irrigation, m³/ha</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@Model.Irrigation.CropName</td>
                    <td>@Model.Irrigation.SprinklingM3Ha</td>
                    <td>@Model.Irrigation.DripM3Ha</td>
                    <td>@Model.Irrigation.FurrowM3Ha</td>
                </tr>
            </tbody>
        </table>

        <div class="print-footer">
            <span>@Model.Header.ReportNumber • @Model.Header.ReportDate.ToString("dd.MM.yyyy")</span>
            <span>Page 2 of 6</span>
        </div>
    </section>

    <!-- Page 3: Результаты мониторинга -->
    <section class="page">
        <h2>Monitoring results:</h2>

        <!-- Прогноз погоды -->
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
            <div>
                <strong>Weather Forecast</strong><br />
                <span>@Model.Weather.Region / @Model.Header.District</span>
            </div>
            <div class="muted">@Model.Header.ReportDate.ToString("dd.MM.yyyy")</div>
        </div>

        <!-- Блоки данных -->
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 15px; font-size: 12px;">
            <div>
                <strong>Air Temperature</strong><br />
                <span style="font-size: 14px; font-weight: bold;">@Model.Weather.AirTemp°C</span>
            </div>
            <div>
                <strong>Air Humidity</strong><br />
                <span style="font-size: 14px; font-weight: bold;">@Model.Weather.AirHumidity%</span>
            </div>
            <div>
                <strong>Wind Speed</strong><br />
                <span style="font-size: 14px; font-weight: bold;">@Model.Weather.WindSpeed м/с</span>
            </div>
            <div>
                <strong>Wind Direction</strong><br />
                <span style="font-size: 14px; font-weight: bold;">@Model.Weather.WindDir</span>
            </div>
            <div>
                <strong>Precipitations</strong><br />
                <span style="font-size: 14px; font-weight: bold;">@Model.Weather.PrecipMm мм</span>
            </div>
            <div>
                <strong>Solar Radiation</strong><br />
                <span style="font-size: 14px; font-weight: bold;">@Model.Weather.SolarJPerCm2 Дж/см²</span>
            </div>
            <!-- Пустой блок -->
            <div></div>
        </div>

        <!-- Следующие 7 дней -->
        <h3>Next 7 Days</h3>
        <div style="display: flex; gap: 10px; margin-bottom: 15px;">
            @foreach (var day in Model.Weather.Next7Days.Take(7))
            {
                var icon = day.Icon == "sun" ? "☀️" : "🌧️";
                <div style="text-align: center; padding: 10px; background: #f8faf8; border: 1px solid var(--border); border-radius: 5px; flex: 1;">
                    <div style="font-weight: bold;">@day.Date.DayOfWeek.ToString().Substring(0, 2)</div>
                    <div style="font-size: 12px;">@day.Date.Day</div>
                    <div style="margin: 5px 0;">@icon</div>
                    <div style="font-size: 14px; font-weight: bold;">+@day.DayTempC°C</div>
                </div>
            }
        </div>

        <!-- Графики -->
        <h3>Temperature chart</h3>
        <div class="avoid" style="margin-bottom: 15px;">
            @if (!string.IsNullOrEmpty(Model.TempChartSvgBase64))
            {
                <img src="data:image/svg+xml;base64,@Model.TempChartSvgBase64" alt="Temperature" style="width:100%; height:auto;" />
            }
        </div>

        <h3>Precipitation chart</h3>
        <div class="avoid" style="margin-bottom: 15px;">
            @if (!string.IsNullOrEmpty(Model.RainChartSvgBase64))
            {
                <img src="data:image/svg+xml;base64,@Model.RainChartSvgBase64" alt="Precipitation" style="width:100%; height:auto;" />
            }
        </div>

        <h3>Solar Radiation</h3>
        <div class="avoid" style="margin-bottom: 15px;">
            @if (!string.IsNullOrEmpty(Model.SolarChartSvgBase64))
            {
                <img src="data:image/svg+xml;base64,@Model.SolarChartSvgBase64" alt="Solar Radiation" style="width:100%; height:auto;" />
            }
        </div>

        <h3>Total (accumulated) climate indicators</h3>
        <table class="table avoid">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Σ(T°C>7)</th>
                    <th>Σ(T°C>10)</th>
                    <th>Σ(T°C>12)</th>
                    <th>Σ(T°C>15)</th>
                    <th>Fallout (mm)</th>
                    <th>Radiation (MJ/m²)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@Model.ClimaticSumm.Date</td>
                    <td>@Model.ClimaticSumm.Temp7</td>
                    <td>@Model.ClimaticSumm.Temp10</td>
                    <td>@Model.ClimaticSumm.Temp12</td>
                    <td>@Model.ClimaticSumm.Temp15</td>
                    <td>@Model.ClimaticSumm.Fallout</td>
                    <td>@Model.ClimaticSumm.Radiation</td>
                </tr>
            </tbody>
        </table>

        <!-- Предупреждения -->
        <h3>⚠️ Deviation Alerts</h3>
        <div class="muted">
            @Model.Monitoring.WarningText
        </div>

        <div class="print-footer">
            <span>@Model.Header.ReportNumber • @Model.Header.ReportDate.ToString("dd.MM.yyyy")</span>
            <span>Page 3 of 6</span>
        </div>
    </section>

    <!-- Page 4: Удобрения и этапы -->
    <section class="page">
        <!-- Календарь мероприятий -->
        <h2>Typical agrotechnical calendar</h2>
        <table class="table avoid">
            <thead>
                <tr>
                    <th>Days from sowing date</th>
                    <th>Activity name</th>
                    <th>Note (standards)</th>
                    <th>Soil recommendations</th>
                    <th>Operation date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Calendar.Rows)
                {
                    <tr>
                        <td>@row.DayOffset</td>
                        <td>@row.Activity</td>
                        <td>@row.Notes</td>
                        <td>@row.Recommendation</td>
                        <td>@row.ActualDate</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Информация о севообороте -->
        <h3>Crop Rotation Information</h3>
        <table class="table avoid">
            <thead>
                <tr>
                    <th>Crop</th>
                    <th>Planned Sowing Date</th>
                    <th>Actual Sowing Date</th>
                    <th>Area ha</th>
                    <th>Planned Harvest Date</th>
                    <th>Actual Harvest Date</th>
                    <th>Yield per hectare</th>
                    <th>Harvest</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@Model.CropRotation.CropName</td>
                    <td>@(Model.CropRotation.PlannedSowingDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                    <td>@(Model.CropRotation.ActualSowingDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                    <td>@Model.CropRotation.AreaHa.ToString("F1")</td>
                    <td>@(Model.CropRotation.PlannedHarvestDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                    <td>@(Model.CropRotation.ActualHarvestDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                    <td>@Model.CropRotation.YieldPerHectare.ToString("F1")</td>
                    <td>@(Model.CropRotation.HarvestDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                </tr>
            </tbody>
        </table>

        <h3>Fertilizers, pesticides</h3>
        <table class="table avoid">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Name</th>
                    <th>Quantity</th>
                    <th>Unit of measurement</th>
                    <th>Crop</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.FertPest.Rows)
                {
                    <tr>
                        <td>@row.Date</td>
                        <td>@row.Type</td>
                        <td>@row.Name</td>
                        <td>@row.Quantity</td>
                        <td>@row.UnitOfMeasurement</td>
                        <td>@row.Crop</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="print-footer">
            <span>@Model.Header.ReportNumber • @Model.Header.ReportDate.ToString("dd.MM.yyyy")</span>
            <span>Page 4 of 6</span>
        </div>
    </section>

    <!-- Page 5: Индексы -->
    <section class="page">
        <h2 style="color: #2e7d32; text-align: left; font-size: 24px; margin-bottom: 20px;">Vegetation Indices</h2>
        
        @if (Model.Indices.IndexImages != null && Model.Indices.IndexImages.Count > 0)
        {
            <table style="width: 100%; border-collapse: collapse; border: 1px solid #e0e0e0;">
                <thead>
                    <tr style="background-color: #f5f5f5;">
                        <th style="padding: 12px; border: 1px solid #e0e0e0; text-align: left; font-weight: bold;">Index</th>
                        <th style="padding: 12px; border: 1px solid #e0e0e0; text-align: center; font-weight: bold;">Value</th>
                        <th style="padding: 12px; border: 1px solid #e0e0e0; text-align: left; font-weight: bold;">Anomaly Coordinates</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var indexImage in Model.Indices.IndexImages)
                    {
                        <tr>
                            <td style="padding: 12px; border: 1px solid #e0e0e0; vertical-align: top;">
                                <strong>@indexImage.IndexType</strong>
                            </td>
                            <td style="padding: 12px; border: 1px solid #e0e0e0; text-align: center; vertical-align: middle;">
                                @if (!string.IsNullOrEmpty(indexImage.ImageBase64))
                                {
                                    <img src="data:image/png;base64,@indexImage.ImageBase64" alt="@indexImage.IndexType" style="width: 150px; height: 150px; object-fit: contain; border: 1px solid #ddd; border-radius: 4px;" />
                                }
                                else
                                {
                                    <div style="width: 150px; height: 150px; background-color: #f5f5f5; border: 1px solid #ddd; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #999;">
                                        No data
                                    </div>
                                }
                            </td>
                            <td style="padding: 12px; border: 1px solid #e0e0e0; vertical-align: top;">
                                @if (indexImage.AnomalyCoordinates != null && indexImage.AnomalyCoordinates.Count > 0)
                                {
                                    <div style="display: flex; flex-direction: column; gap: 8px;">
                                        @foreach (var coord in indexImage.AnomalyCoordinates)
                                        {
                                            <div style="background-color: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 4px; padding: 8px; font-size: 12px;">
                                                <div style="margin-bottom: 4px;"><strong>Latitude:</strong> @coord.Latitude.ToString("F5")</div>
                                                <div><strong>Longitude:</strong> @coord.Longitude.ToString("F5")</div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div style="color: #999; font-size: 12px;">No anomalies detected</div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div style="padding: 20px; text-align: center; color: #999;">
                No index data available
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Indices.Recommendations))
        {
            <h3 style="margin-top: 30px; margin-bottom: 10px;">Recommendations:</h3>
            <div class="muted">@Model.Indices.Recommendations</div>
        }

        <div class="print-footer">
            <span>@Model.Header.ReportNumber • @Model.Header.ReportDate.ToString("dd.MM.yyyy")</span>
            <span>Page 5 of 6</span>
        </div>
    </section>

    <!-- Page 6: Подробный анализ -->
    <section class="page">
        <h2>Подробный анализ культуры</h2>

        <div>  </div>

        <h3>Наземное обследование</h3>
        <table class="table avoid">
            <thead>
                <tr>
                    <th>Период работы</th>
                    <th>Статус</th>
                    <th>Культура</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.BidResults.Rows)
                {
                    <tr>
                        <td>@row.WorkPeriod</td>
                        <td>@row.Status</td>
                        <td>@row.Crop</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.AnomalyTable?.Rows != null && Model.AnomalyTable?.Rows.Count > 0)
        {
            <h3>Anomalies in photographs</h3>

            <table class="table">
                <thead>
                    <tr>
                        <th>Photo</th>
                        <th>Crop</th>
                        <th>anomaly_presence</th>
                        <th>anomaly_description</th>
                        <th>problem_type</th>
                        <th>anomaly1</th>
                        <th>anomaly2</th>
                        <th>classification_description</th>
                        <th>recommendations</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.AnomalyTable.Rows)
                    {
                        <tr>
                            <td style="width:260px">
                                @if (!string.IsNullOrWhiteSpace(r.PhotoDataUri))
                                {
                                    <img src="@r.PhotoDataUri" style="max-width:240px;max-height:240px;border:1px solid #DFE7E3;border-radius:10px;" />
                                }
                                else
                                {
                                    <span>Фото не найдено в архиве</span>
                                }
                            </td>
                            <td>@(r.Crop ?? "-")</td>
                            <td>@r.AnomalyPresence</td>
                            <td>@(r.AnomalyDescription ?? "-")</td>
                            <td>@(r.ProblemType ?? "-")</td>
                            <td>@(r.Anomaly1 ?? "-")</td>
                            <td>@(r.Anomaly2 ?? "-")</td>
                            <td>@(r.ClassificationDescription ?? "-")</td>
                            <td>@(r.Recommendations ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="print-footer">
            <span>@Model.Header.ReportNumber • @Model.Header.ReportDate.ToString("dd.MM.yyyy")</span>
            <span>Page 6 of 6</span>
        </div>
    </section>

</body>
</html>